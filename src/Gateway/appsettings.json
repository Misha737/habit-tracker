{
  "Logging": { "LogLevel": { "Default": "Information", "Yarp": "Warning" } },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "core-route": {
        "ClusterId": "core-cluster",
        "Match": { "Path": "/core/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/users/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/users/{**catch-all}" }
        ]
      },
      "workflow-route": {
        "ClusterId": "workflow-cluster",
        "Match": { "Path": "/workflows/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/workflows/{**catch-all}" }
        ]
      },
      "joinings-route": {
        "ClusterId": "workflow-cluster",
        "Match": { "Path": "/joinings/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/joinings/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "core-cluster": {
        "Destinations": {
          "core-api": { "Address": "http://core-api:8080/" }
        }
      },
      "users-cluster": {
        "Destinations": {
          "users-service": { "Address": "http://users-service:8080/" }
        }
      },
      "workflow-cluster": {
        "Destinations": {
          "workflow-service": { "Address": "http://workflow-service:8080/" }
        }
      }
    }
  }
}
